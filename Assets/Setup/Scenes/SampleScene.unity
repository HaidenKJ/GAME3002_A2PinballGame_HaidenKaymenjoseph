    - target: {fileID: 3991901638957623055, guid: ade9c7323dbcbd645bf8eb2e4a1201e2, type: 3}
      propertyPath: m_Text
      value: "How To Play:\n\nCharge the Plunger to launch the ball, \nscore points
        by having your ball hit\nthe bumpers, and use the flippers \nto prolong how
        long your ball remains\non the table.\n\nHit the Glowling White Bash Toy
        for\n500 points\n\nYou have 3 balls\n\n--------------------------------------------------\nControls:\n\n-
        Hold SPACE to charge plunger\n- A & D to activate Flippers\n\n- Press R to
        reset ball\n"
      objectReference: {fileID: 0}
    - target: {fileID: 5398459039572216820, guid: ade9c7323dbcbd645bf8eb2e4a1201e2, type: 3}
      propertyPath: m_Range
      value: 15
      objectReference: {fileID: 0}
    - target: {fileID: 5398459039572216820, guid: ade9c7323dbcbd645bf8eb2e4a1201e2, type: 3}
      propertyPath: m_Intensity
      value: 9000
      objectReference: {fileID: 0}
    - target: {fileID: 5566655426120332598, guid: ade9c7323dbcbd645bf8eb2e4a1201e2, type: 3}
      propertyPath: m_Name
      value: ---- Pinball Machine ----
      objectReference: {fileID: 0}
    - target: {fileID: 7195366718040623300, guid: ade9c7323dbcbd645bf8eb2e4a1201e2, type: 3}
      propertyPath: m_Text
      value: 'CONFIG:


        - Pressing 1 gives you a ball

        - Pressing
        2 removes a ball

        - Up Arrow increase spring constant

        -
        Down Arrow decrease spring constant

        - Right Arrow increase damper

        -
        Left Arrow decrease damper'
      objectReference: {fileID: 0}
    - target: {fileID: 7195366718040623300, guid: ade9c7323dbcbd645bf8eb2e4a1201e2, type: 3}
